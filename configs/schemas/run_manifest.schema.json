{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.llmtermproject/schemas/run_manifest.schema.json",
  "title": "Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "created_at",
    "phase",
    "system",
    "model",
    "dataset",
    "config_path",
    "seed",
    "input_paths",
    "output_paths"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "phase": {
      "type": "string",
      "pattern": "^[0-9]{2}_.+"
    },
    "system": {
      "type": "string",
      "enum": ["baseline", "gate_only", "gate_plus_verifier", "preflight", "validation"]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "local_path", "quantized", "attn_implementation"],
      "properties": {
        "model_id": {"type": "string", "minLength": 1},
        "local_path": {"type": "string", "minLength": 1},
        "quantized": {"type": "boolean"},
        "attn_implementation": {"type": "string", "minLength": 1}
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "split", "example_count"],
      "properties": {
        "name": {"type": "string", "enum": ["asqa", "finance", "mixed", "contract_sample"]},
        "split": {"type": "string", "minLength": 1},
        "example_count": {"type": "integer", "minimum": 0}
      }
    },
    "config_path": {
      "type": "string",
      "minLength": 1
    },
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "input_paths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "output_paths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
