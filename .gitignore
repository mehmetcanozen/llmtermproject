# Generated outputs. Keep final lightweight report/evaluation artifacts needed
# for fresh-clone verification, but not bulky embeddings or full run folders.
outputs/*
!outputs/final/
!outputs/final/**
!outputs/evaluation/
!outputs/evaluation/*.json
!outputs/evaluation/*.csv
!outputs/distractor_evaluation/
!outputs/distractor_evaluation/*.json
!outputs/distractor_evaluation/*.csv
!outputs/retrieval/
outputs/retrieval/*
!outputs/retrieval/asqa_candidates.jsonl
!outputs/retrieval/finance_candidates.jsonl
!outputs/retrieval/retrieval_index_manifest.json

# Scratch output from tests and local experiments
outputs/test/
artifacts/tmp/
artifacts/cache/
docs/REPAIR_PLUS_VERIFIER_RUNBOOK.md

# Do not vendor downloaded third-party reference repositories.
external/ALCE_reference/
